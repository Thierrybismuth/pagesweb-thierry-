<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simulateur CEE – Les Artisans Verts</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--gd:#0d3b1a;--gm:#2e7d32;--gl:#43a047;--gp:#e8f5e9;--gn:#f1f8f2;--bd:#0d47a1;--bm:#1565c0;--bp:#e3f2fd;--rd:#b71c1c;--rp:#ffebee;--od:#e65100;--op:#fff3e0;--bg:#f0f4f1;--tx:#1a2a1b;--tm:#4a5c4b;--tl:#7a8f7b;--br:#dee7df;--sh:0 2px 16px rgba(27,94,32,.10)}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;font-size:15px}
header{background:#fff;border-bottom:3px solid var(--gm);padding:0 32px;display:flex;align-items:center;gap:16px;height:66px;box-shadow:0 1px 6px rgba(27,94,32,.08);position:sticky;top:0;z-index:100}
.lmark{width:40px;height:40px;flex-shrink:0}
.lbrand{font-size:14px;font-weight:700;color:#1b5e20;line-height:1.1}
.lsub{font-size:11px;color:var(--tl)}
.hsep{width:1px;height:30px;background:var(--br);margin:0 4px}
.htitle h1{font-size:17px;font-weight:700}
.htitle p{font-size:12px;color:var(--tl)}
.hbadge{background:var(--gp);color:#1b5e20;font-size:11px;font-weight:600;padding:5px 12px;border-radius:20px;border:1px solid rgba(46,125,50,.2);white-space:nowrap;margin-left:auto}
.pwrap{background:#fff;border-bottom:1px solid var(--br);padding:0 32px}
.pinner{max-width:900px;margin:0 auto;display:flex;align-items:center;padding:14px 0}
.sdot{width:30px;height:30px;border-radius:50%;background:var(--br);color:var(--tl);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;transition:all .3s;flex-shrink:0}
.sdot.active{background:var(--gm);color:#fff;box-shadow:0 0 0 4px rgba(46,125,50,.15)}
.sdot.done{background:var(--gl);color:#fff}
.sname{font-size:12px;font-weight:500;color:var(--tl);white-space:nowrap;margin-left:8px}
.sname.active{color:#1b5e20;font-weight:700}
.sline{flex:1;height:2px;background:var(--br);margin:0 10px;min-width:16px}
.sline.done{background:var(--gl)}
.wrap{max-width:900px;margin:0 auto;padding:28px 16px 60px}
.al{border-radius:10px;padding:14px 18px;font-size:13px;display:flex;align-items:flex-start;gap:12px;margin-bottom:20px;line-height:1.5}
.al i{font-size:18px;flex-shrink:0;margin-top:-1px}
.al-d{background:var(--rp);border-left:4px solid var(--rd);color:var(--rd)}
.al-w{background:var(--op);border-left:4px solid var(--od);color:#6d2600}
.al-s{background:var(--gp);border-left:4px solid var(--gm);color:#1b5e20}
.al-i{background:var(--bp);border-left:4px solid var(--bm);color:var(--bd)}
.card{background:#fff;border-radius:14px;box-shadow:var(--sh);padding:32px;margin-bottom:20px;border:1px solid rgba(0,0,0,.04)}
.sh2{font-size:20px;font-weight:700;margin-bottom:4px}
.sp{font-size:13px;color:var(--tl);margin-bottom:24px}
.stag{display:inline-flex;align-items:center;gap:6px;background:var(--gn);color:#1b5e20;padding:5px 14px;border-radius:20px;font-size:12px;font-weight:600;margin-bottom:16px;border:1px solid rgba(46,125,50,.2)}
.stag.bl{background:var(--bp);color:var(--bd);border-color:rgba(21,101,192,.2)}
.stag.or{background:var(--op);color:var(--od);border-color:rgba(230,81,0,.2)}
.div{border:none;border-top:1px solid var(--br);margin:22px 0}
.fg{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.fg.c3{grid-template-columns:1fr 1fr 1fr}
.fi{display:flex;flex-direction:column;gap:6px}
.fi.full{grid-column:1/-1}
.lbl{font-size:12px;font-weight:600;color:var(--tm);letter-spacing:.3px;text-transform:uppercase}
.req{color:var(--rd)}
.hlp{font-size:11px;color:var(--tl);margin-top:3px}
input[type=text],input[type=number],input[type=email],input[type=tel],input[type=date],select{border:1.5px solid var(--br);border-radius:8px;padding:10px 14px;font-size:14px;font-family:'Outfit',sans-serif;color:var(--tx);background:#fff;transition:border-color .2s,box-shadow .2s;width:100%}
input:focus,select:focus{outline:none;border-color:var(--gm);box-shadow:0 0 0 3px rgba(46,125,50,.12)}
.zbrow{display:flex;gap:8px;flex-wrap:wrap}
.zb{padding:9px 18px;border:2px solid var(--br);border-radius:8px;background:#fff;cursor:pointer;font-size:13px;font-weight:600;font-family:'Outfit',sans-serif;color:var(--tm);transition:all .2s}
.zb:hover{border-color:var(--gm);color:#1b5e20}
.zb.s{border-color:var(--gm);background:var(--gp);color:#1b5e20}
.pg{display:flex;gap:10px;flex-wrap:wrap}
.pl{padding:9px 20px;border:2px solid var(--br);border-radius:8px;cursor:pointer;font-size:13px;font-weight:500;font-family:'Outfit',sans-serif;transition:all .2s;user-select:none;display:flex;align-items:center;gap:8px;color:var(--tm)}
.pl:hover{border-color:var(--gm)}
.pl input[type=radio]{accent-color:var(--gm);width:15px;height:15px}
.pl.s{border-color:var(--gm);background:var(--gp);color:#1b5e20;font-weight:600}
.btn{padding:12px 28px;border-radius:8px;border:none;font-size:14px;font-weight:700;font-family:'Outfit',sans-serif;cursor:pointer;transition:all .2s;display:inline-flex;align-items:center;gap:8px}
.btn-p{background:var(--gm);color:#fff}
.btn-p:hover{background:#1b5e20;transform:translateY(-1px);box-shadow:0 4px 12px rgba(46,125,50,.3)}
.btn-g{background:transparent;color:var(--gm);border:2px solid var(--gm)}
.btn-g:hover{background:var(--gp)}
.bgrp{display:flex;gap:12px;justify-content:flex-end;margin-top:28px;padding-top:20px;border-top:1px solid var(--br)}
.ss{display:none}
.ss.active{display:block}
#res{display:none}
.sban{background:linear-gradient(135deg,#0d3b1a 0%,#0d47a1 100%);color:#fff;border-radius:16px;padding:28px 32px;margin-bottom:24px;display:flex;align-items:center;gap:32px;position:relative;overflow:hidden}
.sban::before{content:'';position:absolute;right:-30px;top:-30px;width:200px;height:200px;background:rgba(255,255,255,.04);border-radius:50%}
.tblk{flex-shrink:0;text-align:center}
.tlbl{font-size:11px;opacity:.7;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px}
.tval{font-size:48px;font-weight:800;line-height:1;letter-spacing:-1px}
.tunit{font-size:13px;opacity:.7;margin-top:2px}
.ssep{width:1px;height:80px;background:rgba(255,255,255,.2)}
.sright{flex:1}
.si{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.1);font-size:13px}
.si:last-child{border-bottom:none}
.sikwh{font-weight:700;font-size:14px}
.sdsc{font-size:11px;opacity:.55;margin-top:12px}
.rbar{background:#fff;border-radius:10px;padding:14px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;border:1px solid var(--br)}
.rcl{font-weight:700;font-size:15px;color:#1b5e20}
.rmt{font-size:12px;color:var(--tl)}
.ract{display:flex;gap:8px}
.fc{background:#fff;border-radius:12px;border:2px solid var(--br);margin-bottom:14px;overflow:hidden}
.fc.el{border-color:var(--gm)}
.fc.sp{border-color:var(--rd)}
.fh{display:flex;align-items:center;gap:14px;padding:18px 22px;cursor:pointer;transition:background .15s}
.fh:hover{background:#fafafa}
.fc.el .fh{background:var(--gn)}
.fc.sp .fh{background:var(--rp)}
.fref{padding:4px 10px;border-radius:6px;font-size:11px;font-weight:800;letter-spacing:.5px;white-space:nowrap;flex-shrink:0}
.fc.el .fref{background:var(--gm);color:#fff}
.fc.sp .fref{background:var(--rd);color:#fff}
.fc:not(.el):not(.sp) .fref{background:var(--br);color:var(--tl)}
.fnm{font-size:15px;font-weight:700}
.fdsc{font-size:11px;color:var(--tl);margin-top:2px;font-style:italic}
.fst{font-size:12px;margin-top:3px}
.fc.el .fst{color:var(--gm)}
.fc.sp .fst{color:var(--rd)}
.fc:not(.el):not(.sp) .fst{color:var(--tl)}
.fkwh{text-align:right;flex-shrink:0}
.kwn{font-size:22px;font-weight:800;color:var(--bd);line-height:1}
.kwu{font-size:10px;color:var(--tl);text-transform:uppercase;letter-spacing:.5px}
.kweur{font-size:13px;font-weight:700;color:var(--gm);margin-top:3px}
.fbody{padding:20px 22px;border-top:1px solid var(--br);display:none}
.cl{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
.cl li{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--tm);padding:6px 10px;border-radius:6px;background:#f8f9f8}
.ci{flex-shrink:0;font-size:14px}
.cl li.ok{background:var(--gn);color:#1b5e20}
.cl li.fail{background:var(--rp);color:var(--rd)}
.fnote{font-size:12px;color:var(--tl);line-height:1.6;margin-bottom:12px}
.pbdg{display:flex;align-items:flex-start;gap:10px;background:var(--bp);border-radius:8px;padding:12px 14px;font-size:12px;color:var(--bd)}
.tsup{display:inline-block;background:var(--rd);color:#fff;font-size:9px;font-weight:800;padding:2px 7px;border-radius:4px;letter-spacing:.5px;vertical-align:middle;margin-left:6px;text-transform:uppercase}
.pfc{background:#fff;border-radius:14px;border:2px solid var(--gm);margin-bottom:20px;overflow:hidden}
.pfh{background:var(--gp);padding:18px 24px;border-bottom:1px solid rgba(46,125,50,.2)}
.pfh h3{font-size:16px;font-weight:700;color:#1b5e20}
.pfh p{font-size:12px;color:var(--gl)}
.pfb{padding:24px}
.cftxt{background:var(--gn);border-radius:8px;padding:14px 16px;font-size:12px;color:#1b5e20;line-height:1.6;margin:16px 0;border-left:3px solid var(--gm)}
.sigrow{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:20px;padding-top:20px;border-top:1px dashed var(--br)}
.sigbox{border:1.5px dashed var(--br);border-radius:8px;padding:16px;min-height:80px;background:#fafafa;display:flex;align-items:flex-end;font-size:11px;color:var(--tl)}
.nsgrd{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-top:16px}
.nsi{border-radius:12px;padding:20px;text-align:center}
.nsemoji{font-size:28px;margin-bottom:10px}
.nstitle{font-size:13px;font-weight:700;margin-bottom:6px}
.nssub{font-size:12px;color:var(--tl);margin-bottom:14px;line-height:1.4}
.alink{display:inline-block;padding:8px 16px;border-radius:7px;font-size:12px;font-weight:700;font-family:'Outfit',sans-serif;text-decoration:none;cursor:pointer;border:none}
.ag{background:var(--gm);color:#fff}
.ab{background:var(--bm);color:#fff}
.ap{background:#7b1fa2;color:#fff}
.loading{position:fixed;inset:0;background:rgba(255,255,255,.9);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:999;gap:16px}
.spinner{width:48px;height:48px;border:4px solid var(--br);border-top-color:var(--gm);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading p{font-size:15px;font-weight:600;color:var(--gm)}
@media print{.no-print{display:none!important}header{position:relative}.pwrap{display:none}#form-card{display:none!important}#res{display:block!important}body{background:#fff}.sban{-webkit-print-color-adjust:exact;print-color-adjust:exact}}
@media(max-width:640px){header{padding:0 16px}.wrap{padding:16px 12px 60px}.card{padding:20px 16px}.fg{grid-template-columns:1fr}.fg.c3{grid-template-columns:1fr}.sban{flex-direction:column;gap:16px}.ssep{width:100%;height:1px}.nsgrd{grid-template-columns:1fr}.sigrow{grid-template-columns:1fr}.pwrap{display:none}.hbadge{display:none}}
</style>
</head>
<body>
<header>
  <svg class="lmark" viewBox="0 0 44 44" fill="none">
    <polygon points="22,3 41,13.5 41,30.5 22,41 3,30.5 3,13.5" fill="#1b5e20"/>
    <text x="22" y="17" text-anchor="middle" fill="#fff" font-size="5.5" font-family="sans-serif" font-weight="700">LES</text>
    <text x="22" y="25" text-anchor="middle" fill="#fff" font-size="6" font-family="sans-serif" font-weight="800">ARTISANS</text>
    <text x="22" y="33" text-anchor="middle" fill="#fff" font-size="6" font-family="sans-serif" font-weight="800">VERTS</text>
  </svg>
  <div><div class="lbrand">Les Artisans Verts</div><div class="lsub">6 rue Eugène Barbier — 92400 Courbevoie</div></div>
  <div class="hsep"></div>
  <div class="htitle"><h1>Simulateur d'Éligibilité CEE</h1><p>Outil commercial — remplissage en présence du client</p></div>
  <div class="hbadge no-print">⚡ Partenaire CEE EDF</div>
</header>
<div class="pwrap no-print" id="pwrap">
  <div class="pinner">
    <div style="display:flex;align-items:center;gap:8px"><div class="sdot active" id="d1">1</div><span class="sname active" id="l1">Bâtiment</span></div>
    <div class="sline" id="ln1"></div>
    <div style="display:flex;align-items:center;gap:8px"><div class="sdot" id="d2">2</div><span class="sname" id="l2">Éclairage</span></div>
    <div class="sline" id="ln2"></div>
    <div style="display:flex;align-items:center;gap:8px"><div class="sdot" id="d3">3</div><span class="sname" id="l3">Chauffage &amp; Froid</span></div>
    <div class="sline" id="ln3"></div>
    <div style="display:flex;align-items:center;gap:8px"><div class="sdot" id="d4">4</div><span class="sname" id="l4">Résultats</span></div>
  </div>
</div>
<div class="loading" id="loading" style="display:none"><div class="spinner"></div><p>Calcul de l'éligibilité en cours…</p></div>
<div class="wrap">
<div class="card" id="form-card">
<div class="ss active" id="s1">
  <h2 class="sh2">🏢 Identification du site</h2>
  <p class="sp">Informations générales — ces données servent à l'ensemble des fiches CEE</p>
  <div class="fg">
    <div class="fi full"><label class="lbl">Nom / raison sociale <span class="req">*</span></label><input type="text" id="nom" placeholder="Ex: Entrepôt Dupont Logistique SA"></div>
    <div class="fi full"><label class="lbl">Secteur d'activité <span class="req">*</span></label>
      <select id="sec"><option value="">— Sélectionner —</option><option value="industrie">🏭 Industrie / Production</option><option value="entrepot">📦 Entrepôt / Plateforme logistique</option><option value="commerce_grand">🛒 Commerce ≥ 400 m²</option><option value="commerce_petit">🛍️ Commerce &lt; 400 m²</option><option value="sante">🏥 Santé</option><option value="bureaux">💼 Bureaux / Restauration</option><option value="hotel">🏨 Hôtellerie</option><option value="enseignement">🎓 Enseignement</option></select>
    </div>
    <div class="fi"><label class="lbl">Surface totale au sol <span class="req">*</span></label><input type="number" id="surf" placeholder="Ex: 10000" min="0"><span class="hlp">m² — utilisée pour toutes les fiches</span></div>
    <div class="fi"><label class="lbl">Hauteur sous plafond <span class="req">*</span></label><input type="number" id="haut" placeholder="Ex: 10" min="0" step="0.5"><span class="hlp">mètres</span></div>
    <div class="fi full"><label class="lbl">Zone climatique</label>
      <div class="zbrow">
        <button class="zb s" onclick="setZ(this,'H1')" type="button">🌧️ H1 — Nord</button>
        <button class="zb" onclick="setZ(this,'H2')" type="button">🌤️ H2 — Centre / ÎdF</button>
        <button class="zb" onclick="setZ(this,'H3')" type="button">☀️ H3 — Sud / PACA</button>
      </div>
      <input type="hidden" id="zon" value="H1">
    </div>
    <div class="fi"><label class="lbl">Bâtiment existant &gt; 2 ans ?</label>
      <div class="pg"><label class="pl s" id="pe-o"><input type="radio" name="exist" value="oui" checked> ✅ Oui</label><label class="pl" id="pe-n"><input type="radio" name="exist" value="non"> ❌ Non (neuf)</label></div>
    </div>
    <div class="fi"><label class="lbl">Local complètement clos ?</label>
      <div class="pg"><label class="pl s" id="pc-o"><input type="radio" name="clos" value="oui" checked> ✅ Oui</label><label class="pl" id="pc-n"><input type="radio" name="clos" value="non"> ❌ Non / Semi-ouvert</label></div>
    </div>
  </div>
  <hr class="div">
  <div class="stag or">🏗️ Toiture — BAT-EN-101</div>
  <div class="fg">
    <div class="fi"><label class="lbl">Type de toiture</label>
      <select id="ttoiture"><option value="terrasse">Toiture terrasse (plate)</option><option value="versants">Toiture à versants</option><option value="shed">Shed / dents de scie</option><option value="inconnue">Non renseigné</option></select>
    </div>
    <div class="fi"><label class="lbl">Isolation toiture existante</label>
      <select id="isoexist"><option value="aucune">Aucune isolation (dalle béton nue)</option><option value="insuffisante">Insuffisante (R &lt; 2 m².K/W)</option><option value="correcte">Déjà correcte (R ≥ 4 m².K/W)</option><option value="inconnue">Non renseigné</option></select>
    </div>
  </div>
  <div class="bgrp"><button class="btn btn-p" onclick="go(2)">Étape suivante →</button></div>
</div>
<div class="ss" id="s2">
  <h2 class="sh2">💡 Éclairage</h2>
  <p class="sp">Installations lumineuses intérieures et extérieures</p>
  <div class="stag">💡 Éclairage intérieur — BAT-EQ-127 &amp; BAT-EQ-133</div>
  <div class="al al-d"><i>⛔</i><div><strong>BAT-EQ-127 supprimée le 24/02/2026.</strong> La fiche <strong>BAT-EQ-133</strong> (LED + détecteurs de présence / gradation) reste active.</div></div>
  <div class="fg">
    <div class="fi"><label class="lbl">Type d'éclairage intérieur actuel</label>
      <select id="tecl"><option value="tube_fluo">Tubes fluorescents / néons</option><option value="sodium">Sodium HP / vapeur de mercure</option><option value="mixte">Mixte</option><option value="halogene">Halogènes</option><option value="led_ancien">LEDs existantes</option></select>
    </div>
    <div class="fi"><label class="lbl">Nombre de luminaires intérieurs</label><input type="number" id="nblum" placeholder="Ex: 300" min="0"><span class="hlp">Recommandé : 1 LED / 30 m²</span></div>
    <div class="fi"><label class="lbl">Type de LED envisagé</label>
      <select id="tled"><option value="ufo">Rond suspendu — UFO POWER 250 (Thaleos)</option><option value="lineaire">Tube linéaire — LINEAR POWER 250 (Thaleos)</option></select>
    </div>
    <div class="fi"><label class="lbl">Détecteurs présence/luminosité à installer ?</label>
      <select id="detecteurs"><option value="oui_nouveau">Oui — prévus avec les luminaires</option><option value="deja">Déjà en place</option><option value="non">Non prévus</option></select>
      <span class="hlp">Requis pour BAT-EQ-133 (remplaçant de BAT-EQ-127)</span>
    </div>
    <div class="fi"><label class="lbl">Nacelle disponible côté client ?</label>
      <div class="pg"><label class="pl" id="pnac-o"><input type="radio" name="nac" value="oui"> ✅ Oui</label><label class="pl s" id="pnac-n"><input type="radio" name="nac" value="non" checked> ❌ Non</label></div>
    </div>
  </div>
  <hr class="div">
  <div class="stag">🔦 Éclairage extérieur — RES-EC-104</div>
  <div class="fi" style="margin-bottom:16px"><label class="lbl">Éclairage extérieur présent (parking, quais, voiries) ?</label>
    <div class="pg"><label class="pl" id="pext-o" onclick="showExt('oui')"><input type="radio" name="extlum" value="oui"> ✅ Oui</label><label class="pl s" id="pext-n" onclick="showExt('non')"><input type="radio" name="extlum" value="non" checked> ❌ Non</label></div>
  </div>
  <div id="extdets" style="display:none">
    <div class="fg">
      <div class="fi"><label class="lbl">Type d'éclairage extérieur actuel</label>
        <select id="teclext"><option value="sodium">Sodium HP (orange)</option><option value="mercure">Vapeur de mercure</option><option value="halogene">Halogènes / iodures</option><option value="led_ancien">LEDs (déjà remplacé)</option></select>
      </div>
      <div class="fi"><label class="lbl">Nombre de points d'éclairage extérieur</label><input type="number" id="nbext" placeholder="Ex: 40" min="0"></div>
    </div>
  </div>
  <div class="bgrp"><button class="btn btn-g" onclick="go(1)">← Retour</button><button class="btn btn-p" onclick="go(3)">Étape suivante →</button></div>
</div>
<div class="ss" id="s3">
  <h2 class="sh2">🌡️ Chauffage, Ventilation &amp; Froid</h2>
  <p class="sp">Systèmes thermiques et frigorifiques du site</p>
  <div class="stag">🔥 Chauffage — IND-BA-110 &amp; BAT-TH-127</div>
