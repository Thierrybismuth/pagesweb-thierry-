<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jovan Milanovic — Opticien-Lunetier</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --off-white: #f7f5f0;
    --navy: #1a2e44;
    --terracotta: #c8873a;
    --light-navy: #2c4a6e;
    --muted: #8a9ab0;
    --border: #ddd8cf;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--off-white);
    font-family: 'Outfit', sans-serif;
    color: var(--navy);
    min-height: 100vh;
  }

  .top-bar {
    background: var(--navy);
    padding: 14px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .top-bar .brand {
    font-family: 'Cormorant Garamond', serif;
    color: var(--off-white);
    font-size: 1rem;
    letter-spacing: 0.12em;
    opacity: 0.85;
  }
  .top-bar .badge {
    background: var(--terracotta);
    color: white;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 2px;
  }

  .hero {
    background: var(--navy);
    padding: 60px 40px 50px;
    position: relative;
    overflow: hidden;
  }
  .hero::after {
    content: '';
    position: absolute;
    right: -60px;
    top: -60px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    border: 60px solid rgba(200,135,58,0.08);
    pointer-events: none;
  }
  .hero-inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    align-items: flex-end;
    gap: 40px;
  }
  .avatar-ring {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    border: 3px solid var(--terracotta);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: rgba(200,135,58,0.12);
  }
  .avatar-initials {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: var(--terracotta);
    font-weight: 300;
  }
  .hero-text h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    font-weight: 300;
    color: var(--off-white);
    letter-spacing: 0.04em;
    line-height: 1.1;
  }
  .hero-text h1 span {
    color: var(--terracotta);
  }
  .hero-text .subtitle {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 8px;
  }

  .contacts-strip {
    background: #14253a;
    padding: 16px 40px;
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--off-white);
    opacity: 0.82;
    font-size: 0.84rem;
  }
  .contact-item .icon {
    color: var(--terracotta);
    font-size: 1rem;
  }
  .contact-item a {
    color: inherit;
    text-decoration: none;
  }
  .contact-item a:hover { color: var(--terracotta); }

  .main {
    max-width: 860px;
    margin: 0 auto;
    padding: 50px 40px 80px;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 50px;
    align-items: start;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--navy);
    letter-spacing: 0.06em;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--terracotta);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-title::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 18px;
    background: var(--terracotta);
    border-radius: 2px;
  }

  .profil-text {
    font-size: 0.92rem;
    line-height: 1.8;
    color: #3a4f66;
    font-weight: 300;
  }

  .exp-block { margin-bottom: 28px; }
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 6px;
  }
  .exp-title { font-weight: 600; font-size: 0.95rem; color: var(--navy); }
  .exp-company {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    color: var(--terracotta);
    font-style: italic;
  }
  .exp-date { font-size: 0.78rem; color: var(--muted); font-weight: 400; white-space: nowrap; margin-top: 2px; }
  .exp-location { font-size: 0.78rem; color: var(--muted); margin-bottom: 8px; display: flex; align-items: center; gap: 4px; }
  .exp-desc { font-size: 0.86rem; line-height: 1.7; color: #4a5f76; font-weight: 300; }
  .exp-divider { height: 1px; background: var(--border); margin: 24px 0; }

  .formation-block { margin-bottom: 20px; }
  .formation-title { font-weight: 600; font-size: 0.93rem; color: var(--navy); }
  .formation-school { font-family: 'Cormorant Garamond', serif; font-size: 1rem; color: var(--terracotta); font-style: italic; }
  .formation-date { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }
  .formation-mention {
    display: inline-block;
    margin-top: 4px;
    font-size: 0.73rem;
    background: rgba(200,135,58,0.12);
    color: var(--terracotta);
    padding: 2px 8px;
    border-radius: 2px;
    font-weight: 500;
  }

  .sidebar-section { margin-bottom: 36px; }

  .skills-list { display: flex; flex-wrap: wrap; gap: 8px; }
  .skill-pill {
    background: var(--navy);
    color: var(--off-white);
    font-size: 0.75rem;
    font-weight: 400;
    padding: 5px 12px;
    border-radius: 2px;
    letter-spacing: 0.05em;
  }
  .skill-pill.secondary {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--navy);
  }

  .langue-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    font-size: 0.85rem;
    color: var(--navy);
  }
  .langue-dots { display: flex; gap: 4px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); }
  .dot.filled { background: var(--terracotta); }

  .outil-tag {
    display: inline-block;
    background: rgba(26,46,68,0.07);
    color: var(--navy);
    font-size: 0.76rem;
    padding: 4px 10px;
    border-radius: 2px;
    margin: 3px 3px 3px 0;
    font-weight: 500;
  }

  .hobby-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.84rem;
    color: #4a5f76;
    margin-bottom: 6px;
    font-weight: 300;
  }
  .hobby-item::before { content: '→'; color: var(--terracotta); font-size: 0.8rem; }

  .note-block {
    margin-top: 40px;
    border: 1px dashed var(--border);
    border-radius: 4px;
    padding: 20px 24px;
    background: rgba(200,135,58,0.04);
  }
  .note-block .note-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--terracotta);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .note-block p { font-size: 0.84rem; line-height: 1.7; color: #4a5f76; font-weight: 300; }

  footer {
    border-top: 1px solid var(--border);
    padding: 20px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    color: var(--muted);
  }
  footer .brand-footer { font-family: 'Cormorant Garamond', serif; color: var(--navy); font-size: 0.9rem; }

  @media (max-width: 720px) {
    .main { grid-template-columns: 1fr; padding: 30px 20px 60px; }
    .hero { padding: 40px 20px; }
    .hero-text h1 { font-size: 2.2rem; }
    .contacts-strip { padding: 12px 20px; gap: 16px; }
    .top-bar { padding: 12px 20px; }
  }
</style>
</head>
<body>

<div class="top-bar">
